# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno requeridas por Transavic
# Copiá este archivo a `.env` y completá los valores reales.
# ─────────────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════
# BASE DE DATOS (Neon Postgres)
# ════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host/db?sslmode=require

# ════════════════════════════════════════════════════════════════════
# NEXTAUTH
# ════════════════════════════════════════════════════════════════════
AUTH_SECRET=string-aleatorio-largo-ejecutar-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# ════════════════════════════════════════════════════════════════════
# GOOGLE MAPS (mismo cliente actual, 2 keys)
# ════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_MAPS_API_KEY=AIzaSy...
# ⚠️ Naming inusual: M mayúscula + guión bajo
Maps_SERVER_KEY=AIzaSy...

# ════════════════════════════════════════════════════════════════════
# UBICACIÓN BASE DEL ALMACÉN (fallback si no hay base_location en DB)
# ════════════════════════════════════════════════════════════════════
BASE_LATITUDE=-12.0464
BASE_LONGITUDE=-77.0428

# ════════════════════════════════════════════════════════════════════
# CRON SECRET (protege endpoints /api/cron/*)
# Generar con: openssl rand -base64 32
# ════════════════════════════════════════════════════════════════════
CRON_SECRET=string-aleatorio-largo

# ════════════════════════════════════════════════════════════════════
# SUNAT — Facturación electrónica (Fase B.4, código stub por ahora)
# ════════════════════════════════════════════════════════════════════

# Ambiente: 'beta' para testing (credenciales MODDATOS funcionan)
#           'production' para facturación real con SUNAT
SUNAT_ENVIRONMENT=beta

# ── Empresa: TRANSAVIC ──
SUNAT_TRA_RUC=20XXXXXXXXX
SUNAT_TRA_RAZON_SOCIAL="Transavic SAC"
SUNAT_TRA_DIRECCION="Av. Ejemplo 123, La Victoria"
SUNAT_TRA_UBIGEO=150115
# Usuario secundario SOL con perfil "Emisión de Documentos Electrónicos" (APIFACTU)
SUNAT_TRA_SOL_USER=MODDATOS
SUNAT_TRA_SOL_PASSWORD=moddatos
# Certificado digital tributario (.p12) en Base64
# Conseguir gratis en SUNAT (hasta 31-dic-2027) en menú SOL > Certificado Digital Tributario
SUNAT_TRA_CERT_PASS=
SUNAT_TRA_CERT_B64=

# ── Empresa: AVÍCOLA DE TONY ──
SUNAT_AVI_RUC=20YYYYYYYYY
SUNAT_AVI_RAZON_SOCIAL="Avícola de Tony SAC"
SUNAT_AVI_DIRECCION=""
SUNAT_AVI_UBIGEO=150115
SUNAT_AVI_SOL_USER=MODDATOS
SUNAT_AVI_SOL_PASSWORD=moddatos
SUNAT_AVI_CERT_PASS=
SUNAT_AVI_CERT_B64=

# ════════════════════════════════════════════════════════════════════
# (Fase C) — Pusher para tracking GPS en vivo
# ════════════════════════════════════════════════════════════════════
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=
# NEXT_PUBLIC_PUSHER_KEY=

# ════════════════════════════════════════════════════════════════════
# (Fase C) — Gemini API para IA comercial
# ════════════════════════════════════════════════════════════════════
# Cuenta dedicada: transavicdev@gmail.com (no mezclar con otros proyectos)
# Crear en: https://aistudio.google.com/app/apikey
# Modelo recomendado: gemini-flash-latest (free tier generoso)
# ⚠️ Anonimizar nombres de clientes antes de mandar prompts
GEMINI_API_KEY=AIzaSy...

# ────────────────────────────────────────────────────────────────────
# Groq — RESPALDO de IA cuando Gemini falla (429 u otro error)
# ────────────────────────────────────────────────────────────────────
# Free tier, sin tarjeta. Crear API key en: https://console.groq.com/keys
# Si no se define GROQ_API_KEY, NO hay respaldo (todo sigue igual que hoy).
# Recibe los mismos prompts ya anonimizados que Gemini (misma privacidad).
# GROQ_MODEL es opcional (default llama-3.3-70b-versatile).
#   Alternativa de alto volumen: llama-3.1-8b-instant (14.4K req/día).
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ════════════════════════════════════════════════════════════════════
# SMTP — Para enviar comprobantes (PDF + XML) por correo al cliente
# ════════════════════════════════════════════════════════════════════
# Recomendado: Gmail con app password
# 1. Activar 2FA en la cuenta Gmail
# 2. Generar "Contraseña de aplicación" en https://myaccount.google.com/apppasswords
# 3. Pegar esa contraseña abajo (NO la contraseña normal de Gmail)
#
# Alternativas: SendGrid, Mailgun, Mailtrap (testing), Brevo, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false              # true si usás puerto 465 (SSL)
SMTP_USER=tu-email@gmail.com
SMTP_PASS=app-password-aqui    # contraseña de aplicación de Gmail, no la normal
SMTP_FROM_NAME=Transavic
SMTP_FROM_EMAIL=               # opcional, default = SMTP_USER
