# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env*.local

# credenciales reales (NUNCA subir) — claves SUNAT, SMTP, etc.
*.local.md
CREDENCIALES*.md
.credenciales*

# certificados digitales SUNAT (.p12/.pfx) — JAMÁS subir (contienen llave privada)
certificados/
*.p12
*.pfx

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local test/ref directories
/recursos/
/scratch/
